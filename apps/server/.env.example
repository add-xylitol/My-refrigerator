ENVIRONMENT=local
LOG_LEVEL=INFO
LOCAL_MODE=true

# Supabase (leave defaults for local mode)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key
SUPABASE_ANON_KEY=anon-key

# AI Model (GLM-5V-Turbo via Zhipu AI)
OPENAI_API_KEY=sk-xxxx
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
OPENAI_VISION_MODEL=glm-4v-flash
OPENAI_CHAT_MODEL=glm-4-flash

JWT_SECRET=replace-with-generated-secret
JWT_EXPIRES_MINUTES=60

# WeChat Mini Program (for production)
WX_APPID=your-wechat-appid
WX_SECRET=your-wechat-secret
